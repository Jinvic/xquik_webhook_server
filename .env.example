# 复制本文件为 .env 后填写真实值：cp .env.example .env
# 切勿将 .env 提交到版本库。

# Xquik 控制台创建 Webhook 时生成的密钥（HMAC 验签用）
WEBHOOK_SECRET=

# 监听地址，默认 :8080。Docker 内一般保持 :8080
HTTP_ADDR=:8080

# SMTP（默认 465 为 SMTPS 隐式 TLS；若使用 587 则走 STARTTLS）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# 发件人、收件人（多个收件人用英文逗号分隔）
MAIL_FROM=
MAIL_TO=

# 仅 docker-compose.yml 使用：映射到容器的宿主机端口
# HTTP_PORT=8080
